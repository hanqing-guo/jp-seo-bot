# ───────────────────────────────────────────────────────────
# フロントエンドが呼ぶ「記事生成バックエンド」の URL
#
# 使い方: このファイルを「.env」にコピーして使う
#     cp .env.example .env
# 空のままだと記事は「プレビュー(API 未接続)」テンプレートになります。
# ───────────────────────────────────────────────────────────

# ローカルで Deno バックエンドを動かす場合(`npm run api:local`):
VITE_API_BASE=http://localhost:8000

# Supabase クラウドにデプロイした後はこちらに切替:
# VITE_API_BASE=https://<your-project-ref>.supabase.co/functions/v1
