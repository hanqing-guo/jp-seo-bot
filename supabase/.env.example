# ───────────────────────────────────────────────────────────
# AI 記事生成用 API キー(バックエンド側)
#
# 使い方:
#   1. このファイルを同じフォルダに「.env」という名前でコピー
#        cp supabase/.env.example supabase/.env
#   2. 下の DEEPSEEK_API_KEY を自分の本物のキーに書き換える
#   (.env は .gitignore 済み。git には絶対に上がりません)
# ───────────────────────────────────────────────────────────

# DeepSeek(推奨・低コスト)。https://platform.deepseek.com/api_keys で発行
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude を使う場合は上を空にして、こちらにキーを入れる:
# ANTHROPIC_API_KEY=

# API 共有シークレット(任意)。設定すると /api/* は x-api-key ヘッダ必須になる。
# フロント側 .env の VITE_API_SECRET と同じ値にする(Vercel では両方を env に設定)。
# API_SECRET=

# SERP 実測(/api/serp-check)用。https://dataforseo.com で発行(従量・1 クエリ約 ¥1)。
# 未設定なら実測チェックは「未接続」表示になり、ヒューリスティック KD のみで動く。
# DATAFORSEO_LOGIN=
# DATAFORSEO_PASSWORD=
